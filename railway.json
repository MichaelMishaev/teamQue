{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": ["/apps/api/**", "/apps/web/**"]
  },
  "deploy": {
    "preDeployCommand": "pnpm --filter api db:migrate",
    "startCommand": "pnpm --filter api start"
  }
}
