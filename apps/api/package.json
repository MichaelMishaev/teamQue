    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.28",
    "@node-rs/argon2": "^2.0.2",
    "cookie-parser": "^1.4.7",
    "drizzle-orm": "^0.45.0",
    "helmet": "^8.2.0",
    "nestjs-pino": "^4.6.0",
    "pg": "^8.22.0",
    "pino": "^10.0.0",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
