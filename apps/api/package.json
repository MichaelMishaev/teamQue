{
  "name": "api",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "cookie-parser": "^1.4.7",
    "drizzle-orm": "^0.45.0",
    "helmet": "^8.2.0",
    "nestjs-pino": "^4.6.0",
    "pg": "^8.22.0",
    "pino": "^10.0.0",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "shared": "workspace:*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.23.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
